#  Application 
APP_NAME=ThreatBrain
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0


#  Backend Server 
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


#  Frontend 
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_APP_NAME=ThreatBrain


#  Supabase
# Get these from https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Same Supabase keys exposed to the frontend (use VITE_ prefix)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here


#  Security / JWT 
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_me_with_a_random_64_character_hex_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7


#  Groq AI 
# Get from https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2
GROQ_MAX_TOKENS=4096


#  Threat Intelligence APIs 

# AbuseIPDB — https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=your_abuseipdb_key_here
ABUSEIPDB_BASE_URL=https://api.abuseipdb.com/api/v2

# VirusTotal — https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_key_here
VIRUSTOTAL_BASE_URL=https://www.virustotal.com/api/v3

# Shodan — https://account.shodan.io
SHODAN_API_KEY=your_shodan_key_here
SHODAN_BASE_URL=https://api.shodan.io

# AlienVault OTX — https://otx.alienvault.com/api
OTX_API_KEY=your_otx_key_here
OTX_BASE_URL=https://otx.alienvault.com/api/v1


#  Notifications 

# Discord webhook URL for critical alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here

# Resend (email) — https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=alerts@yourdomain.com


#  N8N Automation 
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook
N8N_API_KEY=your_n8n_api_key_here


#  Rate Limiting 
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000


#  Logging 
LOG_LEVEL=INFO
LOG_FORMAT=json